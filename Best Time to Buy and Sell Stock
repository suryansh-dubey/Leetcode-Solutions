class Solution {
    public int maxProfit(int[] prices) {
        int buyprices = Integer.MAX_VALUE;
        int max_profit = 0;
        for(int i =0;i<prices.length;i++){
            if(buyprices < prices[i]){
                int profit = prices[i] - buyprices ;
                max_profit = Math.max(max_profit,profit);
            }
            else{
                buyprices=prices[i];
            }
            
    }
    return max_profit;
}

}
